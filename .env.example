DTOOLS_BASE_URL=https://api.d-tools.example

# Required auth model for D-Tools Cloud API requests:
# 1) Fixed Basic authorization value (handled automatically by script)
# 2) Your API key in X-API-Key header
DTOOLS_API_KEY=b7e1d9533f2d4f359d47c5e92ce9cb892ab7bf49d1dd4c049f

# Endpoints are customizable in case your tenant uses different paths.
DTOOLS_SEARCH_PATH=/cloud/api/v1/catalog/items/search
DTOOLS_PRICING_PATH=/cloud/api/v1/catalog/items/{item_id}/pricing

# Optional: output currency and timeout
DTOOLS_CURRENCY=USD
DTOOLS_TIMEOUT_SECONDS=20
